  <!-- Help Page -->
  <data name="Help_Title" xml:space="preserve">
    <value>Symbolic Link vs Hard Link</value>
  </data>
  <data name="Help_SymbolicLink" xml:space="preserve">
    <value>Symbolic Link</value>
  </data>
  <data name="Help_SymbolicLinkDesc" xml:space="preserve">
    <value>• Works like a shortcut, points to the original file/folder path
• Supports both files and directories
• Can link across different drives/volumes
• Can link to network paths
• If original is deleted, symbolic link becomes broken
• Requires Developer Mode or Administrator privileges to create</value>
  </data>
  <data name="Help_HardLink" xml:space="preserve">
    <value>Hard Link</value>
  </data>
  <data name="Help_HardLinkDesc" xml:space="preserve">
    <value>• Creates another reference to the same file data on disk
• Only supports files, not directories
• Must be on the same drive/volume as the original
• Cannot link to network paths
• If original is deleted, hard link still works (data persists)
• Does not require special privileges to create</value>
  </data>
  <data name="Help_BatchLink" xml:space="preserve">
    <value>Batch File Launcher</value>
  </data>
  <data name="Help_BatchLinkDesc" xml:space="preserve">
    <value>• Creates a .bat script that launches the source file
• Allows setting a custom Working Directory
• Useful for programs that require specific execution environments
• No special privileges required</value>
  </data>
  <data name="Help_ShortcutLink" xml:space="preserve">
    <value>Windows Shortcut</value>
  </data>
  <data name="Help_ShortcutLinkDesc" xml:space="preserve">
    <value>• Creates a standard Windows Shell Link (.lnk)
• Allows setting a custom "Start in" directory
• Most compatible with all Windows applications
• No special privileges required</value>
  </data>
  <data name="Help_ExecutableNoteTitle" xml:space="preserve">
    <value>Special Note for Executables</value>
  </data>
  <data name="Help_ExecutableNote" xml:space="preserve">
    <value>Executable files launched from symbolic links keep the original image filename, whereas those launched from hard links use the hard link's name as the image filename. This can cause malfunctions in programs that rely on the original image filename or path. Therefore, it is recommended to use symbolic links for executable files.
Additionally, whether using a symbolic or hard link, launching from File Explorer sets the working directory to the link's location. This may cause issues for programs with strict coding assumptions.
In such cases, use a traditional shortcut and modify its "Start in" property to the original executable's directory.
Alternatively, write a batch script to change the working directory before launching the executable.</value>
  </data>

