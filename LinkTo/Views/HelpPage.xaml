<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LinkTo.Views.HelpPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LinkTo.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="0,0,0,20">

            <TextBlock x:Name="HelpTitle" Text="Symbolic Link vs Hard Link" 
                       Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Symbolic Link -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE71B;" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock x:Name="SymbolicLinkTitle" Text="Symbolic Link" 
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="SymbolicLinkDesc" 
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="• Works like a shortcut, points to the original file/folder path&#x0a;• Supports both files and directories&#x0a;• Can link across different drives/volumes&#x0a;• Can link to network paths&#x0a;• If original is deleted, symbolic link becomes broken&#x0a;• Requires Developer Mode or Administrator privileges to create" />
                </StackPanel>
            </Border>

            <!-- Hard Link -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8D7;" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock x:Name="HardLinkTitle" Text="Hard Link" 
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="HardLinkDesc" 
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="• Creates another reference to the same file data on disk&#x0a;• Only supports files, not directories&#x0a;• Must be on the same drive/volume as the original&#x0a;• Cannot link to network paths&#x0a;• If original is deleted, hard link still works (data persists)&#x0a;• Does not require special privileges to create" />
                </StackPanel>
            </Border>

            <!-- Batch File -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE756;" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock x:Name="BatchLinkTitle" Text="Batch File" 
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="BatchLinkDesc" 
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Windows Shortcut -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE71B;" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock x:Name="ShortcutLinkTitle" Text="Windows Shortcut" 
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="ShortcutLinkDesc" 
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Executable Note -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE946;" Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" />
                        <TextBlock x:Name="ExecutableNoteTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="ExecutableNoteDesc" 
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
