<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LinkTo.Views.CreateLinkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LinkTo.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:LinkTo.Models"
    mc:Ignorable="d"
    AllowDrop="True"
    DragOver="Page_DragOver"
    Drop="Page_Drop">

    <Page.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Scrollable Content Area -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" Padding="0,0,0,16">
                
                <!-- Source File/Directory Group -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="SourceGroupHeader" Text="Source File / Directory" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Name="DragDropHint" Text="Drag and drop file or folder here" 
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                   FontStyle="Italic" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SourcePathTextBox" 
                                     PlaceholderText="Select file or folder..."
                                     IsReadOnly="True"
                                     Grid.Column="0" />
                            <Button x:Name="BrowseFileButton" Content="File..." 
                                    Click="BrowseFile_Click" Grid.Column="1" />
                            <Button x:Name="BrowseFolderButton" Content="Folder..." 
                                    Click="BrowseFolder_Click" Grid.Column="2" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Target Directory Group -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="TargetGroupHeader" Text="Target Directory" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TargetPathTextBox" 
                                     PlaceholderText="Select target directory..."
                                     TextChanged="TargetPathTextBox_TextChanged"
                                     Grid.Column="0" />
                            <Button x:Name="BrowseTargetButton" Content="Browse..." 
                                    Click="BrowseTarget_Click" Grid.Column="1" />
                        </Grid>
                        
                        <!-- Common Directories Expander -->
                        <Expander x:Name="CommonDirsExpander" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <TextBlock x:Name="CommonDirsHeader" Text="Common Directories" />
                            </Expander.Header>
                            <Expander.Content>
                                <ListView x:Name="CommonDirsList" 
                                          MaxHeight="150"
                                          SelectionMode="None"
                                          IsItemClickEnabled="True"
                                          ItemClick="CommonDirsList_ItemClick" />
                            </Expander.Content>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- Link Name Group -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="LinkNameGroupHeader" Text="Link Name" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBox x:Name="LinkNameTextBox" PlaceholderText="Enter link name..." />
                    </StackPanel>
                </Border>

                <!-- Working Directory Group (Conditional) -->
                <Border x:Name="WorkingDirectoryBorder" Style="{StaticResource CardBorderStyle}" Visibility="Collapsed">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="WorkingDirHeader" Text="Working Directory" Style="{StaticResource SubtitleTextBlockStyle}" />
                         <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="WorkingDirTextBox" 
                                     PlaceholderText="Select working directory..."
                                     Grid.Column="0" />
                            <Button x:Name="BrowseWorkingDirButton" Content="Browse..." 
                                    Click="BrowseWorkingDir_Click" Grid.Column="1" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Link Type Group -->
                <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                    <Expander x:Name="LinkTypeExpander" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="False"
                              Expanding="LinkTypeExpander_Expanding" Collapsed="LinkTypeExpander_Collapsed">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock x:Name="LinkTypeGroupHeader" Text="Link Type" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <Border x:Name="LinkTypeSelectedBorder"
                                        Background="{ThemeResource ControlAltFillColorTertiaryBrush}"
                                        CornerRadius="4"
                                        Padding="8,4"
                                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="LinkTypeSelectedText" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Border>
                            </StackPanel>
                        </Expander.Header>
                        <Expander.Content>
                            <StackPanel Spacing="8" Padding="0,8,0,0">
                                <RadioButton x:Name="SymbolicLinkRadio" 
                                             Content="Symbolic Link" 
                                             IsChecked="True"
                                             GroupName="LinkType"
                                             Checked="LinkType_Checked" />
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <RadioButton x:Name="HardLinkRadio" 
                                                 Grid.Column="0"
                                                 Content="Hard Link" 
                                                 GroupName="LinkType"
                                                 VerticalAlignment="Center"
                                                 Checked="LinkType_Checked" />
                                    <StackPanel x:Name="HardLinkInfoPanel"
                                                Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center"
                                                Visibility="Collapsed">
                                        <FontIcon Glyph="&#xE7BA;" 
                                                  FontFamily="Segoe MDL2 Assets" 
                                                  Foreground="{ThemeResource SystemFillColorCautionBrush}" 
                                                  FontSize="16" />
                                        <TextBlock x:Name="HardLinkInfoText" 
                                                   VerticalAlignment="Center" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                                <RadioButton x:Name="BatchLinkRadio" 
                                             Content="Batch File (.bat)" 
                                             GroupName="LinkType"
                                             Checked="LinkType_Checked" />
                                <RadioButton x:Name="ShortcutLinkRadio" 
                                             Content="Windows Shortcut (.lnk)" 
                                             GroupName="LinkType"
                                             Checked="LinkType_Checked" />
                            </StackPanel>
                        </Expander.Content>
                    </Expander>
                </Border>

                <!-- Extended Options Group -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="ExtendedOptionsHeader" x:Uid="Group_ExtendedOptions" Text="Extended Options" Style="{StaticResource SubtitleTextBlockStyle}" />
                        
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <CheckBox x:Name="MigrateDataCheckBox" 
                                      x:Uid="MigrateDataCheckBox"
                                      Content="Data Migration" 
                                      Grid.Column="0"
                                      VerticalAlignment="Center"/>
                                      
                            <TextBlock x:Name="DataMigrationDescription" 
                                       x:Uid="DataMigrationDescription"
                                       Text="Move source file/folder to target path before creating link." 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Style="{ThemeResource CaptionTextBlockStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
        
        <!-- Progress Overlay -->
        <StackPanel x:Name="ProgressOverlay" 
                    Grid.Row="1" 
                    Orientation="Horizontal" 
                    Spacing="12" 
                    HorizontalAlignment="Center" 
                    Visibility="Collapsed"
                    Margin="0,-40,0,0">
            <ProgressRing IsActive="True" Width="20" Height="20" />
            <TextBlock x:Name="ProgressStatusText" x:Uid="Status_Processing" Text="Processing..." VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Fixed Create Link Button at Bottom -->
        <Button x:Name="CreateLinkButton" 
                Grid.Row="1"
                Content="Create Link"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Stretch"
                Height="40"
                Margin="0,16,0,0"
                Click="CreateLink_Click" />
    </Grid>
</Page>
